    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.1",
